# deps
node_modules/
.corepack/
.pnpm-store/
.cache/

# build
dist/
*.tsbuildinfo
.next/
next-env.d.ts

# env
.env
.env.local

# IDE
.vscode/
.idea/

# Claude Code session-local config
.claude/
# Exceptions: project-level artifacts shared across the team.
# Skills + agents are the Agentic OS — tracked. See CLAUDE.md and vault/README.md.
!.claude/
!.claude/skills/
!.claude/skills/**
!.claude/agents/
!.claude/agents/*.md
# ...but session-local config stays out of the repo. These re-ignore lines
# must come AFTER the negations above — otherwise `!.claude/` re-exposes them.
.claude/settings.local.json
.claude/launch.json

# OS
.DS_Store
Thumbs.db

# logs
*.log
npm-debug.log*
pnpm-debug.log*

# postgres data
.postgres-data/

# git worktrees
.worktrees/

# scraper raw data
packages/scraper/data/vfx-raw/*.json
packages/scraper/data/vfx-raw/**/*.json

# Playwright artifacts
apps/web/test-results/
apps/web/playwright-report/

# Python bytecode (Modal deploy artifacts on Windows)
__pycache__/
*.pyc
*.pyo
*.ps1

.vercel

# Generated deck/presentation artifacts — repo-root output/, packages/db/output/, etc.
output/
# ...but vault/output/ is tracked project memory (the Agentic OS deliverables
# tier), not generated output. Re-include the directory, then its contents.
!vault/output/
!vault/output/**
slide-*.jpg
/CineCanon_Monetization_Pitch.pptx

# Office lock files
~$*
