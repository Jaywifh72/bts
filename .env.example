# Postgres dev DB (Docker local)
DATABASE_URL=postgres://bts:bts@localhost:5432/bts_dev

# Postgres test DB (separate database, same instance)
TEST_DATABASE_URL=postgres://bts:bts@localhost:5432/bts_test

# Video discovery — YouTube Data API v3
# Obtain from Google Cloud Console → APIs & Services → YouTube Data API v3
YOUTUBE_API_KEY=

# Video discovery — Vimeo API
# Obtain from https://developer.vimeo.com → My Apps → New App → Authentication
VIMEO_ACCESS_TOKEN=

# Web app — admin gate
# Single shared token. Required to access /admin/*. Set in apps/web/.env.local.
# Replace the value with a long random string in production.
ADMIN_TOKEN=

# Web app — fully-qualified base URL (no trailing slash)
# Used by sitemap.xml, robots.txt, JSON-LD canonical IDs, and OG image URLs.
# Falls back to http://localhost:3000 in development.
NEXT_PUBLIC_SITE_URL=https://studiopro.example.com

# TMDb v4 Read Access Token (themoviedb.org → Settings → API)
# Used by both the scraper (tmdb:import) and the web app (poster/backdrop fetch).
# Set in BOTH packages/scraper/.env and apps/web/.env.local.
TMDB_READ_ACCESS_TOKEN=

# ─── Optional / production-only ────────────────────────────────────────────

# Postgres pool size override. Default 10; set lower (2-4) for parallel
# build environments where multiple Next.js workers would otherwise blow
# past the server's max_connections ceiling.
# DATABASE_POOL_MAX=10

# Upstash Redis — distributed rate limit backend. Without these, rate
# limits fall back to in-memory (fine for dev, useless on serverless prod).
# See docs/runbooks/upstash-redis.md for setup.
# UPSTASH_REDIS_REST_URL=https://<id>.upstash.io
# UPSTASH_REDIS_REST_TOKEN=

# Sentry DSN — error tracking. Without this, @sentry/nextjs is a no-op.
# See docs/runbooks/sentry.md for the wizard invocation.
# NEXT_PUBLIC_SENTRY_DSN=https://<key>@<org>.ingest.sentry.io/<project>

# SigLIP-2 inference endpoint for /lookbook visual reverse search.
# Returns 1152-dim normalised image embeddings matching the
# production_keyframes.embedding column. Without this, /api/lookbook/search
# responds 503 with a documented error.
# See docs/runbooks/siglip2-inference.md to deploy via Modal.
# SIGLIP_ENCODER_URL=https://<org>--siglip2-embeddings-siglipencoder-encode.modal.run

# OpenAI API key — text embeddings (text-embedding-3-small) for semantic
# search over productions + people. Only needed if running the embedding
# generators in packages/scraper/src/embeddings/.
# OPENAI_API_KEY=

# GitHub Personal Access Token — only needed if running the wayback
# health check or any repo-introspection scrapers.
# GITHUB_TOKEN=
